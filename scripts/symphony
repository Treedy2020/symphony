#!/bin/sh
# Wrapper: locate mise-installed escript and run the symphony binary.
# The actual escript lives at $HOME/.local/bin/.symphony-escript (installed by ./scripts/install.sh).
ESCRIPT=$(ls -d "$HOME/.local/share/mise/installs/erlang"/*/bin/escript 2>/dev/null | sort -V | tail -1)
if [ -z "$ESCRIPT" ]; then
  echo "Error: escript not found. Run: mise install erlang" >&2
  exit 1
fi
exec "$ESCRIPT" "$HOME/.local/bin/.symphony-escript" "$@"
